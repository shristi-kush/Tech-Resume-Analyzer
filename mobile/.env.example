# --- Local dev (default for frontend) ---
# Terminal 1: cd backend && python app.py
# Terminal 2: cd mobile && npm run start:local
# EXPO_PUBLIC_API_URL=http://localhost:5000

# On a physical phone, localhost is rewritten to your PC's LAN IP (from Expo Metro).
# Android emulator uses 10.0.2.2 automatically. Use http, not https.

# --- Production (Render) ---
EXPO_PUBLIC_API_URL=https://tech-resume-analyzer-1.onrender.com
